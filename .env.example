# App
SECRET_KEY=change-me-in-production-use-long-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
DATABASE_URL=sqlite+aiosqlite:///./markdept.db

# Anthropic OAuth (register at console.anthropic.com)
ANTHROPIC_CLIENT_ID=
ANTHROPIC_CLIENT_SECRET=
ANTHROPIC_REDIRECT_URI=http://localhost:8000/auth/callback
ANTHROPIC_SCOPE=org:read_claude

# Mastodon (register at your instance's /settings/applications)
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

# LinkedIn (register at developer.linkedin.com)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Lemmy
LEMMY_INSTANCE_URL=https://lemmy.world

# YouTube / Google (register at console.cloud.google.com)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/platforms/youtube/callback

# Scheduler
SCHEDULER_TIMEZONE=UTC
