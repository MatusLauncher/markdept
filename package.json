{
  "name": "markdept",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev:server": "bun run --watch src/index.ts",
    "dev:client": "bunx vite client/",
    "dev": "bun run dev:server & bun run dev:client",
    "build": "bunx vite build client/",
    "start": "bun run build && bun src/index.ts",
    "db:push": "bunx drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate",
    "typecheck": "bunx tsc --noEmit && cd client && bunx tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.36.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "bun-types": "^1.1.34",
    "drizzle-kit": "^0.27.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "@tanstack/react-query": "^5.56.0",
    "vite": "^5.4.0"
  }
}
